#include<stdio.h>
#include<stdlib.h>
#include<time.h>

int main(){
    int p=23,q=11,g=2,x=3,k,h=9,r,s;
    srand(time(0));
    k=rand()%10+1;
    r=(g*k)%q;
    s=((h + x*r)*k)%q;
    printf("Message Hash: %d",h);
    printf("\nRandom k: %d",k);
    printf("\nSignature (r,s): (%d,%d)",r,s);
    return 0;
}
